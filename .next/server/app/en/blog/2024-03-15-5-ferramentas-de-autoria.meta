{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/blog/layout,_N_T_/[locale]/blog/[slug]/layout,_N_T_/[locale]/blog/[slug]/page,_N_T_/en/blog/2024-03-15-5-ferramentas-de-autoria"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/blog/$d$slug/__PAGE__",
    "/$d$locale/blog/$d$slug",
    "/$d$locale/blog",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}